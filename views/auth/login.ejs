<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="brand-icon-lg">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
      </div>
      <h1 class="auth-title">TransformIQ</h1>
      <p class="auth-sub">Association Platform</p>
    </div>

    <form method="POST" action="/login" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-input" placeholder="you@organisation.com" required autofocus>
      </div>

      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-input" placeholder="••••••••" required>
      </div>

      <button type="submit" class="btn-primary btn-full">Sign In</button>
    </form>

    <p class="auth-alt">Don't have an account? <a href="/register">Register</a></p>
  </div>
</div>
