<div class="container">
  <div class="page-header">
    <h1>📋 Requirements <span class="count-badge"><%= entities.length %></span></h1>
    <a href="/projects/<%= project.id %>" class="btn-outline">← Project</a>
  </div>

  <!-- Filters -->
  <form method="GET" class="filter-bar">
    <select name="req_type"       class="form-input filter-input" onchange="this.form.submit()">
      <option value="">All Types</option>
      <option value="functional"    <%= filters.req_type==='functional'?'selected':'' %>>Functional</option>
      <option value="non-functional"<%= filters.req_type==='non-functional'?'selected':'' %>>Non-functional</option>
    </select>
    <select name="priority"       class="form-input filter-input" onchange="this.form.submit()">
      <option value="">All Priorities</option>
      <option value="high"  <%= filters.priority==='high'  ?'selected':'' %>>High</option>
      <option value="medium"<%= filters.priority==='medium'?'selected':'' %>>Medium</option>
      <option value="low"   <%= filters.priority==='low'   ?'selected':'' %>>Low</option>
    </select>
    <select name="status"         class="form-input filter-input" onchange="this.form.submit()">
      <option value="">All Statuses</option>
      <option value="pending"  <%= filters.status==='pending'  ?'selected':'' %>>Pending</option>
      <option value="confirmed"<%= filters.status==='confirmed'?'selected':'' %>>Confirmed</option>
      <option value="rejected" <%= filters.status==='rejected' ?'selected':'' %>>Rejected</option>
    </select>
    <input type="number" name="confidence_min" class="form-input filter-input"
      placeholder="Min confidence (0–1)" step="0.1" min="0" max="1"
      value="<%= filters.confidence_min || '' %>" style="width:180px;">
    <button type="submit" class="btn-outline btn-sm">Filter</button>
    <a href="/projects/<%= project.id %>/requirements" class="btn-outline btn-sm">Clear</a>
  </form>

  <% if (!entities.length) { %>
    <div class="empty-state"><p>No requirements yet. Upload a source and extract entities.</p></div>
  <% } else { %>
    <!-- Bulk actions -->
    <% if (member.role !== 'viewer') { %>
    <form method="POST" action="/projects/<%= project.id %>/requirements/bulk-action" id="bulk-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="bulk-bar">
        <label><input type="checkbox" id="select-all"> Select all</label>
        <button type="submit" name="action" value="confirm" class="btn-sm btn-primary">✓ Confirm selected</button>
        <button type="submit" name="action" value="reject"  class="btn-sm btn-danger" >✗ Reject selected</button>
      </div>
    <% } %>

    <div class="entity-list">
      <% for (const e of entities) { %>
        <div class="entity-item entity-item-indigo">
          <% if (member.role !== 'viewer') { %>
            <input type="checkbox" name="ids" value="<%= e.id %>" form="bulk-form" class="entity-check">
          <% } %>
          <div class="entity-item-body">
            <div class="entity-item-header">
              <a href="/projects/<%= project.id %>/requirements/<%= e.id %>" class="entity-title"><%= e.title %></a>
              <div class="entity-badges">
                <% if (e.req_type) { %><span class="badge-info"><%= e.req_type %></span><% } %>
                <% if (e.priority) { %>
                  <span class="badge-<%= e.priority === 'high' ? 'danger' : e.priority === 'medium' ? 'warning' : 'muted' %>"><%= e.priority %></span>
                <% } %>
                <span class="badge-<%= e.status === 'confirmed' ? 'success' : e.status === 'rejected' ? 'danger' : 'muted' %>"><%= e.status %></span>
                <% if (e.confidence) { %><span class="confidence-badge"><%= Math.round(e.confidence * 100) %>%</span><% } %>
              </div>
            </div>
            <% if (e.description) { %><p class="entity-desc"><%= e.description.slice(0, 200) %><%= e.description.length > 200 ? '...' : '' %></p><% } %>
          </div>
          <% if (member.role !== 'viewer') { %>
          <div class="entity-actions">
            <form method="POST" action="/projects/<%= project.id %>/requirements/<%= e.id %>/confirm" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-sm btn-primary" title="Confirm">✓</button>
            </form>
            <form method="POST" action="/projects/<%= project.id %>/requirements/<%= e.id %>/reject" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-sm btn-danger" title="Reject">✗</button>
            </form>
            <form method="POST" action="/projects/<%= project.id %>/requirements/<%= e.id %>/delete" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-sm btn-danger" onclick="return confirm('Delete?')">🗑</button>
            </form>
          </div>
          <% } %>
        </div>
      <% } %>
    </div>
    <% if (member.role !== 'viewer') { %></form><% } %>
  <% } %>
</div>
<script>
document.getElementById('select-all') && document.getElementById('select-all').addEventListener('change', function(){
  document.querySelectorAll('.entity-check').forEach(c => c.checked = this.checked);
});
</script>
