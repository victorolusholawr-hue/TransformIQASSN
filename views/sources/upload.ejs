<div class="container">
  <div class="page-header">
    <div>
      <h1>Upload Source</h1>
      <p class="page-sub"><a href="/projects/<%= project.id %>"><%= project.name %></a></p>
    </div>
    <a href="/projects/<%= project.id %>/sources" class="btn-outline">View all sources →</a>
  </div>

  <% if (last) { %>
    <div class="upload-success-bar">
      <span class="upload-success-icon">✓</span>
      <span><strong><%= last.name %></strong> uploaded successfully</span>
      <a href="/sources/<%= last.id %>" class="upload-success-link">
        <%= last.ai_status === 'pending' && last.extraction_status !== 'failed' ? 'View & Extract with AI →' : 'View source →' %>
      </a>
    </div>
  <% } %>

  <div class="card">
    <form method="POST" action="/projects/<%= project.id %>/sources/upload" enctype="multipart/form-data" id="upload-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label class="form-label">File *</label>
        <div class="drop-zone" id="drop-zone">
          <div class="drop-zone-icon">📁</div>
          <p class="drop-zone-text">Drag & drop or <label for="file-input" class="drop-zone-link">browse</label></p>
          <p class="drop-zone-hint">Supported: PDF, Word (.docx), PowerPoint (.pptx), Excel (.xlsx), plain text (.txt), images (.png, .jpg)</p>
          <input type="file" id="file-input" name="file" accept=".pdf,.docx,.xlsx,.xls,.txt,.pptx,.png,.jpg,.jpeg,.webp,.gif" required style="display:none;">
          <div id="file-name" class="drop-zone-selected" style="display:none;"></div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Source Type</label>
          <select name="source_type" class="form-input">
            <option value="">Select type...</option>
            <option value="transcript">Meeting Transcript</option>
            <option value="document">Document</option>
            <option value="presentation">Presentation</option>
            <option value="spreadsheet">Spreadsheet</option>
            <option value="image">Image/Screenshot</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label">Participants (comma-separated)</label>
          <input type="text" name="participants" class="form-input" placeholder="Jane Smith, John Doe">
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary" id="upload-btn">Upload &amp; Extract Text</button>
        <a href="/projects/<%= project.id %>" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <div class="notice notice-info" style="margin-top:20px;">
    <strong>What happens next:</strong> After upload, text is extracted automatically for documents.
    For <strong>images</strong>, Claude Vision runs when you click <strong>Extract with AI</strong> (this may take 30–60 s).
    You can then extract Requirements, Stakeholders, Processes, Risks, and more.
  </div>
</div>

<script>
const dz  = document.getElementById('drop-zone');
const fi  = document.getElementById('file-input');
const fn  = document.getElementById('file-name');

fi.addEventListener('change', () => {
  if(fi.files[0]){ fn.textContent = fi.files[0].name; fn.style.display='block'; }
});
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('dragover'); });
dz.addEventListener('dragleave', () => dz.classList.remove('dragover'));
dz.addEventListener('drop', e => {
  e.preventDefault(); dz.classList.remove('dragover');
  fi.files = e.dataTransfer.files;
  if(fi.files[0]){ fn.textContent = fi.files[0].name; fn.style.display='block'; }
});
document.getElementById('upload-form').addEventListener('submit', () => {
  document.getElementById('upload-btn').textContent = 'Uploading...';
  document.getElementById('upload-btn').disabled = true;
});
</script>
