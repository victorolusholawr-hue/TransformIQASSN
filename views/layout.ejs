<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title><%= typeof title !== 'undefined' ? title + ' — TransformIQ' : 'TransformIQ' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/style.css">
  <%- typeof style !== 'undefined' ? style : '' %>
  <script>
    // Apply saved theme before body renders to prevent flash
    (function(){
      try {
        var t = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
      } catch(e) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
    window.tiqCsrfToken = '<%= csrfToken %>';
    window.tiqFetchJson = function(input, init) {
      init = init || {};
      var headers = new Headers(init.headers || {});
      headers.set('Accept', 'application/json');
      headers.set('X-Requested-With', 'XMLHttpRequest');
      var method = (init.method || 'GET').toUpperCase();
      if (!['GET', 'HEAD', 'OPTIONS', 'TRACE'].includes(method)) {
        headers.set('X-CSRF-Token', window.tiqCsrfToken);
        if (init.body instanceof FormData) {
          if (!init.body.has('_csrf')) init.body.append('_csrf', window.tiqCsrfToken);
        }
      }
      init.headers = headers;
      return window.fetch(input, init).then(function(res) {
        var contentType = res.headers.get('content-type') || '';
        if (!contentType.includes('application/json')) {
          return res.text().then(function() {
            var err = new Error('Your session or security token may have expired. Please reload the page and try again.');
            err.status = res.status;
            throw err;
          });
        }
        return res.json().then(function(data) {
          if (!res.ok) {
            var err = new Error((data && data.error) || ('Request failed with HTTP ' + res.status + '.'));
            err.status = res.status;
            err.data = data;
            throw err;
          }
          return data;
        });
      });
    };
    window.tiqRunProjectRecalibration = function(options) {
      options = options || {};
      var btn = options.button;
      if (!btn || btn.disabled) return;
      var projectId = options.projectId;
      var idleText = options.idleText || btn.textContent || 'Recalibrate';
      var actionText = options.actionText || 'Recalibrating';
      var emptyMessage = options.emptyMessage || 'No extracted sources found for this project.';
      var confirmMessage = options.confirmMessage || 'Re-extract all completed sources using the latest AI prompt?';
      if (!projectId || !window.tiqFetchJson) {
        alert('Recalibration is not available. Please reload the page and try again.');
        return;
      }
      if (!confirm(confirmMessage)) return;

      function reset(message) {
        if (message) alert(message);
        btn.disabled = false;
        btn.textContent = idleText;
      }

      function extractSource(id, label) {
        var init = new FormData();
        init.append('phase', 'init');
        return window.tiqFetchJson('/sources/' + id + '/extract', { method: 'POST', body: init })
          .then(function(meta) {
            if (!meta.ok) throw new Error(meta.error || 'Extraction initialization failed.');
            var total = Number(meta.chunks_total || 0);
            if (!total) throw new Error('No extractable text sections were found.');
            function chunk(idx, attempt) {
              if (idx >= total) return Promise.resolve();
              btn.textContent = label + ' section ' + (idx + 1) + '/' + total + '...';
              var f = new FormData();
              f.append('phase', 'chunk');
              f.append('chunk_idx', String(idx));
              f.append('retry_attempt', String(attempt || 0));
              return window.tiqFetchJson('/sources/' + id + '/extract', { method: 'POST', body: f })
                .then(function(data) {
                  if (!data.ok) {
                    if ((attempt || 0) < 2) return chunk(idx, (attempt || 0) + 1);
                    throw new Error(data.error || 'Extraction failed on section ' + (idx + 1) + '.');
                  }
                  return chunk(idx + 1, 0);
                });
            }
            return chunk(0, 0);
          });
      }

      btn.disabled = true;
      btn.textContent = actionText + '...';
      window.tiqFetchJson('/projects/' + projectId + '/sources/done-ids')
        .then(function(data) {
          var ids = data.source_ids || data.ids || [];
          if (!ids.length) {
            reset(emptyMessage);
            return;
          }
          var i = 0;
          function next() {
            if (i >= ids.length) {
              btn.textContent = 'Done - reloading...';
              setTimeout(function() { window.location.reload(); }, 800);
              return;
            }
            var label = actionText + ' ' + (i + 1) + '/' + ids.length;
            btn.textContent = label + '...';
            extractSource(ids[i], label)
              .then(function() { i += 1; next(); })
              .catch(function(err) { reset((err && err.message) || 'Extraction failed.'); });
          }
          next();
        })
        .catch(function(err) {
          reset((err && err.message) || 'Could not fetch source list. Please try again.');
        });
    };
  </script>
</head>
<body>

<%- include('partials/navbar') %>

<div class="page-body">
  <%- include('partials/flash') %>
  <%- body %>
</div>

<%- typeof script !== 'undefined' ? script : '' %>

<script>
document.addEventListener('DOMContentLoaded', function(){
  const root = document.documentElement;
  const buttons = document.querySelectorAll('.theme-btn');

  function setTheme(theme) {
    const next = theme === 'dark' ? 'dark' : 'light';
    root.setAttribute('data-theme', next);
    buttons.forEach(function(btn) {
      const isDark = next === 'dark';
      btn.textContent = isDark ? '☀️' : '🌙';
      btn.title = isDark ? 'Switch to light mode' : 'Switch to dark mode';
      btn.setAttribute('aria-label', btn.title);
    });
    try { localStorage.setItem('theme', next); } catch (_) {}
  }

  buttons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      setTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
    });
  });
  setTheme(root.getAttribute('data-theme') || 'light');
});
</script>
</body>
</html>
