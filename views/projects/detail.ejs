<div class="project-layout">

  <!-- ── Sidebar ─────────────────────────────────────────────────── -->
  <aside class="project-sidebar">
    <div class="project-sidebar-title"><%= project.name %></div>
    <div class="project-sidebar-meta">
      <% if (project.status === 'archived') { %>
        <span class="badge-muted">Archived</span>
      <% } else { %>
        <span class="badge-success">Active</span>
      <% } %>
      <% if (project.tags && project.tags.length) { %>
        <% for (const tag of project.tags.slice(0,2)) { %>
          <span class="badge-muted"><%= tag %></span>
        <% } %>
      <% } %>
    </div>

    <!-- Sources -->
    <div class="sidebar-section-label">Sources</div>
    <a href="/projects/<%= project.id %>/sources" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(114,36,108,0.12);color:var(--primary);">📁</span>
      <span>All Sources</span>
      <span class="sidebar-badge"><%= counts.sources %></span>
    </a>
    <% if (member.role !== 'viewer') { %>
    <a href="/projects/<%= project.id %>/sources/upload" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(114,36,108,0.12);color:var(--primary);">⬆</span>
      <span>Upload Source</span>
    </a>
    <% } %>

    <div class="sidebar-divider"></div>

    <!-- Entities -->
    <div class="sidebar-section-label">Entities</div>
    <a href="/projects/<%= project.id %>/requirements" class="sidebar-link">
      <span class="sidebar-link-icon ec-requirements">📋</span>
      <span>Requirements</span>
      <span class="sidebar-badge"><%= counts.requirements %></span>
    </a>
    <a href="/projects/<%= project.id %>/stakeholders" class="sidebar-link">
      <span class="sidebar-link-icon ec-stakeholders">👥</span>
      <span>Stakeholders</span>
      <span class="sidebar-badge"><%= counts.stakeholders %></span>
    </a>
    <a href="/projects/<%= project.id %>/processes" class="sidebar-link">
      <span class="sidebar-link-icon ec-processes">⚙️</span>
      <span>Processes</span>
      <span class="sidebar-badge"><%= counts.processes %></span>
    </a>
    <a href="/projects/<%= project.id %>/decisions" class="sidebar-link">
      <span class="sidebar-link-icon ec-decisions">✅</span>
      <span>Decisions</span>
      <span class="sidebar-badge"><%= counts.decisions %></span>
    </a>
    <a href="/projects/<%= project.id %>/risks" class="sidebar-link">
      <span class="sidebar-link-icon ec-risks">⚠️</span>
      <span>Risks</span>
      <span class="sidebar-badge"><%= counts.risks %></span>
    </a>
    <a href="/projects/<%= project.id %>/business-rules" class="sidebar-link">
      <span class="sidebar-link-icon ec-business-rules">📏</span>
      <span>Business Rules</span>
      <span class="sidebar-badge"><%= counts.business_rules %></span>
    </a>
    <a href="/projects/<%= project.id %>/systems" class="sidebar-link">
      <span class="sidebar-link-icon ec-systems">🖥️</span>
      <span>Systems</span>
      <span class="sidebar-badge"><%= counts.systems %></span>
    </a>
    <a href="/projects/<%= project.id %>/kpis" class="sidebar-link">
      <span class="sidebar-link-icon ec-kpis">📊</span>
      <span>KPIs</span>
      <span class="sidebar-badge"><%= counts.kpis %></span>
    </a>

    <div class="sidebar-divider"></div>

    <!-- Analysis -->
    <div class="sidebar-section-label">Analysis</div>
    <a href="/projects/<%= project.id %>/graph" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(65,182,230,0.15);color:#41b6e6;">🕸️</span>
      <span>Knowledge Graph</span>
    </a>
    <a href="/projects/<%= project.id %>/traceability" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(65,182,230,0.15);color:#41b6e6;">🔗</span>
      <span>Traceability Matrix</span>
    </a>

    <div class="sidebar-divider"></div>

    <!-- Visualize -->
    <div class="sidebar-section-label">Visualize</div>
    <a href="/projects/<%= project.id %>/visualize/process-map" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(13,148,136,0.12);color:#0D9488;">🗺️</span>
      <span>Process Maps</span>
    </a>
    <a href="/projects/<%= project.id %>/visualize/raci" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(13,148,136,0.12);color:#0D9488;">📐</span>
      <span>RACI Matrix</span>
    </a>
    <a href="/projects/<%= project.id %>/visualize/stakeholder-map" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(13,148,136,0.12);color:#0D9488;">🎯</span>
      <span>Stakeholder Map</span>
    </a>
    <a href="/projects/<%= project.id %>/visualize/gap-analysis" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(13,148,136,0.12);color:#0D9488;">🔍</span>
      <span>Gap Analysis</span>
    </a>
    <a href="/projects/<%= project.id %>/visualize/risk-heatmap" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(220,107,47,0.15);color:#dc6b2f;">🌡️</span>
      <span>Risk Heatmap</span>
    </a>

    <div class="sidebar-divider"></div>

    <!-- AI Insights -->
    <div class="sidebar-section-label">AI Insights</div>
    <a href="/projects/<%= project.id %>/future-state" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(194,24,139,0.12);color:#c2188b;">🚀</span>
      <span>Future State</span>
    </a>
    <a href="/projects/<%= project.id %>/roadmap" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(194,24,139,0.12);color:#c2188b;">🗓️</span>
      <span>Roadmap</span>
    </a>
    <a href="/projects/<%= project.id %>/user-stories" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(194,24,139,0.12);color:#c2188b;">📖</span>
      <span>User Stories</span>
    </a>
    <a href="/projects/<%= project.id %>/acceptance-criteria" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(194,24,139,0.12);color:#c2188b;">✔️</span>
      <span>Acceptance Criteria</span>
    </a>
    <a href="/projects/<%= project.id %>/impact-matrix" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(194,24,139,0.12);color:#c2188b;">⚡</span>
      <span>Impact Matrix</span>
    </a>
    <a href="/projects/<%= project.id %>/voice-capture" class="sidebar-link">
      <span class="sidebar-link-icon" style="background:rgba(194,24,139,0.12);color:#c2188b;">🎙️</span>
      <span>Voice Capture</span>
    </a>

    <div class="sidebar-divider"></div>

    <!-- Export -->
    <% if (member.role !== 'viewer') { %>
      <div class="sidebar-section-label">Export</div>
      <a href="/projects/<%= project.id %>/export" class="sidebar-link">
        <span class="sidebar-link-icon" style="background:rgba(72,162,63,0.12);color:#48a23f;">📤</span>
        <span>Export Documents</span>
      </a>
      <a href="/projects/<%= project.id %>/export/bundle" class="sidebar-link">
        <span class="sidebar-link-icon" style="background:rgba(72,162,63,0.12);color:#48a23f;">📦</span>
        <span>Export Bundle</span>
      </a>
    <% } %>
  </aside>

  <!-- ── Main Content ──────────────────────────────────────────────── -->
  <main class="project-main">

    <!-- Page header -->
    <div class="page-header">
      <div>
        <h1><%= project.name %></h1>
        <% if (project.description) { %><p class="page-sub"><%= project.description %></p><% } %>
      </div>
      <div class="header-actions">
        <% if (member.role !== 'viewer') { %>
          <a href="/projects/<%= project.id %>/sources/upload" class="btn-primary btn-sm">+ Upload Source</a>
          <a href="/projects/<%= project.id %>/edit" class="btn-outline btn-sm">Edit Project</a>
          <button type="button" class="btn-outline btn-sm" id="recalibrateBtn">Recalibrate</button>
          <% if (project.status === 'archived') { %>
            <form method="POST" action="/projects/<%= project.id %>/restore" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-primary btn-sm">Restore</button>
            </form>
          <% } else { %>
            <form method="POST" action="/projects/<%= project.id %>/archive" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-outline btn-sm" onclick="return confirm('Archive this project? It will be hidden from your dashboard.')">Archive</button>
            </form>
          <% } %>
        <% } %>
        <% if (member.role !== 'viewer') { %>
          <a href="/projects/<%= project.id %>/export" class="btn-outline btn-sm">Export</a>
        <% } %>
        <% if (member.role === 'owner') { %>
          <form method="POST" action="/projects/<%= project.id %>/delete" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn-danger btn-sm"
              onclick="return confirm('Delete this project and all its data? This cannot be undone.')">Delete</button>
          </form>
        <% } %>
      </div>
    </div>

    <!-- Entity count overview -->
    <div class="entity-grid">
      <% const entityTypes = [
        { key:'requirements',   label:'Requirements',   icon:'📋', iconClass:'ec-requirements'  },
        { key:'stakeholders',   label:'Stakeholders',   icon:'👥', iconClass:'ec-stakeholders'  },
        { key:'processes',      label:'Processes',      icon:'⚙️',  iconClass:'ec-processes'     },
        { key:'decisions',      label:'Decisions',      icon:'✅', iconClass:'ec-decisions'     },
        { key:'risks',          label:'Risks',          icon:'⚠️', iconClass:'ec-risks'         },
        { key:'business_rules', href:'business-rules', label:'Business Rules', icon:'📏', iconClass:'ec-business-rules'},
        { key:'systems',        label:'Systems',        icon:'🖥️', iconClass:'ec-systems'       },
        { key:'kpis',           label:'KPIs',           icon:'📊', iconClass:'ec-kpis'          },
      ]; %>
      <% for (const et of entityTypes) { %>
        <a href="/projects/<%= project.id %>/<%= et.href || et.key %>" class="entity-card">
          <div class="entity-card-icon <%= et.iconClass %>"><%= et.icon %></div>
          <div class="entity-card-count"><%= counts[et.key] %></div>
          <div class="entity-card-label"><%= et.label %></div>
        </a>
      <% } %>
    </div>

    <% const totalEntities = counts.requirements + counts.stakeholders + counts.processes + counts.decisions + counts.risks + counts.business_rules + counts.systems + counts.kpis; %>
    <% if (totalEntities > 0 || counts.sources > 0) { %>
    <div class="charts-grid" style="margin-bottom:20px;">
      <div class="chart-card">
        <h3>Entity Distribution</h3>
        <div class="chart-canvas-wrap"><canvas id="entityChart"></canvas></div>
      </div>
      <div class="chart-card">
        <h3>Source Extraction Status</h3>
        <div class="chart-canvas-wrap"><canvas id="sourceChart"></canvas></div>
      </div>
    </div>
    <% } %>

    <!-- Team Members -->
    <div class="section">
      <div class="section-header">
        <h3>Team Members</h3>
        <% if (member.role === 'owner') { %>
          <button type="button" class="btn-sm btn-outline" id="invite-toggle"
            aria-controls="invite-form" aria-expanded="false">
            + Invite Member
          </button>
        <% } %>
      </div>

      <div id="invite-form" class="invite-form-panel" hidden>
        <form method="POST" action="/projects/<%= project.id %>/members/invite"
              style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div style="flex:1;min-width:180px;">
            <label class="form-label">Email address</label>
            <input type="email" name="email" id="invite-email" class="form-input" placeholder="colleague@example.com" required>
          </div>
          <div style="width:140px;">
            <label class="form-label">Role</label>
            <select name="role" class="form-input">
              <option value="analyst">Analyst</option>
              <option value="viewer">Viewer</option>
            </select>
          </div>
          <button type="submit" class="btn-primary">Send Invite</button>
          <p class="form-hint" style="width:100%;margin-top:4px;">The person must already have a TransformIQ account.</p>
        </form>
      </div>

      <div class="members-list">
        <% for (const m of members) { %>
          <div class="member-item">
            <div class="member-avatar"><%= m.name.charAt(0).toUpperCase() %></div>
            <div class="member-info">
              <div class="member-name"><%= m.name %></div>
              <div class="member-email"><%= m.email %></div>
            </div>
            <span class="badge-role"><%= m.role %></span>
            <% if (member.role === 'owner' && m.role !== 'owner') { %>
              <form method="POST" action="/projects/<%= project.id %>/members/<%= m.id %>/remove"
                    style="display:inline;">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn-sm btn-danger"
                  onclick="return confirm('Remove this member?')">Remove</button>
              </form>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Recent sources -->
    <div class="section">
      <div class="section-header">
        <h3>Recent Sources</h3>
        <a href="/projects/<%= project.id %>/sources" class="btn-outline btn-sm">View all</a>
      </div>
      <% if (recentSources && recentSources.length) { %>
        <table class="students-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Type</th>
              <th>Words</th>
              <th>AI Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% for (const s of recentSources) { let meta = {}; try { meta = JSON.parse(s.metadata || '{}'); } catch (_) {} %>
              <tr>
                <td><strong><%= s.name %></strong></td>
                <td><span class="badge-muted"><%= s.source_type || 'document' %></span></td>
                <td><%= meta.word_count || '—' %></td>
                <td>
                  <span class="<%= s.ai_status === 'done' ? 'badge-success' : s.ai_status === 'processing' ? 'badge-warning' : s.ai_status === 'failed' ? 'badge-danger' : 'badge-muted' %>">
                    <%= s.ai_status === 'done' ? 'Extracted' : s.ai_status === 'processing' ? 'Processing' : s.ai_status === 'failed' ? 'Failed' : 'Pending' %>
                  </span>
                </td>
                <td class="row-actions">
                  <a href="/sources/<%= s.id %>" class="btn-outline btn-sm">View</a>
                  <% const needsVision = (s.source_type === 'image') || (meta.extraction_method === 'ocr-needs-vision'); %>
                  <% if (member.role !== 'viewer' && (s.extraction_status === 'done' || needsVision) && s.ai_status !== 'done') { %>
                    <a href="/sources/<%= s.id %>" class="btn-primary btn-sm"><%= s.ai_status === 'failed' || s.ai_status === 'processing' ? 'Retry AI' : 'Extract AI' %></a>
                  <% } %>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state"><p>No sources yet. <a href="/projects/<%= project.id %>/sources/upload">Upload your first source.</a></p></div>
      <% } %>
    </div>

    <% if (counts.requirements === 0 && counts.sources > 0) { %>
      <div class="notice notice-warning" style="margin-bottom:20px;">
        <strong>Sources uploaded but no entities extracted yet.</strong>
        Open a source and click "Extract with AI" to analyse it.
      </div>
    <% } %>

  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
  const inviteToggle = document.getElementById('invite-toggle');
  const inviteForm = document.getElementById('invite-form');
  const inviteEmail = document.getElementById('invite-email');
  if (inviteToggle && inviteForm) {
    inviteToggle.addEventListener('click', function() {
      inviteForm.hidden = false;
      inviteForm.classList.add('is-visible');
      inviteToggle.setAttribute('aria-expanded', 'true');
      inviteToggle.hidden = true;
      inviteForm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      if (inviteEmail) inviteEmail.focus();
    });
  }

  const recalibrateBtn = document.getElementById('recalibrateBtn');
  if (recalibrateBtn && window.tiqRunProjectRecalibration) {
    recalibrateBtn.addEventListener('click', function(){
      window.tiqRunProjectRecalibration({
        button: this,
        projectId: '<%= project.id %>',
        idleText: 'Recalibrate',
        actionText: 'Recalibrating',
        emptyMessage: 'No extracted sources found for this project.',
        confirmMessage: 'Re-extract all completed sources using the latest AI prompt? This will update all extracted entities for this project.'
      });
    });
  }

  const entityCtx = document.getElementById('entityChart');
  const sourceCtx = document.getElementById('sourceChart');
  if (window.Chart && entityCtx) {
    const counts = [
      <%= counts.requirements %>, <%= counts.stakeholders %>, <%= counts.processes %>, <%= counts.decisions %>,
      <%= counts.risks %>, <%= counts.business_rules %>, <%= counts.systems %>, <%= counts.kpis %>
    ];
    const labels = ['Requirements','Stakeholders','Processes','Decisions','Risks','Business Rules','Systems','KPIs'];
    const colors = ['#72246c','#41b6e6','#48a23f','#f0b323','#dc6b2f','#c2188b','#3a5dae','#0D9488'];
    const filteredLabels = labels.filter(function(_, i){ return counts[i] > 0; });
    const filteredCounts = counts.filter(function(v){ return v > 0; });
    const filteredColors = colors.filter(function(_, i){ return counts[i] > 0; });
    if (filteredCounts.length) {
      new Chart(entityCtx, {
        type: 'doughnut',
        data: { labels: filteredLabels, datasets: [{ data: filteredCounts, backgroundColor: filteredColors }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right' } } }
      });
    }
  }
  if (window.Chart && sourceCtx) {
    const sourceStatuses = <%- JSON.stringify(sourceStatusCounts || {}) %>;
    new Chart(sourceCtx, {
      type: 'bar',
      data: {
        labels: ['Pending','Processing','Extracted','Failed'],
        datasets: [{
          data: [sourceStatuses.pending || 0, sourceStatuses.processing || 0, sourceStatuses.done || 0, sourceStatuses.failed || 0],
          backgroundColor: ['#97999b','#f0b323','#48a23f','#dc6b2f'],
          borderRadius: 6
        }]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { ticks: { precision: 0 } } } }
    });
  }
})();
</script>
