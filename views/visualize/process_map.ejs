<div class="container">
  <div class="page-header">
    <h1>Process Map</h1>
    <a href="/projects/<%= project.id %>" class="btn-outline">← Project</a>
  </div>

  <% if (!processes.length) { %>
    <div class="empty-state"><p>No processes extracted yet.</p></div>
  <% } else { %>
    <div class="side-layout">
      <div class="side-panel">
        <h3 class="side-panel-title">Processes</h3>
        <% for (const p of processes) { %>
          <a href="?process_id=<%= p.id %>" class="side-item <%= selected && selected.id === p.id ? 'active' : '' %>">
            <%= p.name %>
          </a>
        <% } %>
      </div>
      <div class="side-main">
        <% if (selected) { %>
          <h2><%= selected.name %></h2>
          <% if (selected.description) { %><p><%= selected.description %></p><% } %>
          <% if (selected.mermaid_syntax) { %>
            <div class="mermaid-wrap">
              <div class="mermaid"><%= selected.mermaid_syntax %></div>
            </div>
          <% } else { %>
            <p class="muted">No diagram syntax for this process.</p>
          <% } %>
        <% } else { %>
          <div class="empty-state"><p>Select a process from the left to view its diagram.</p></div>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<script>mermaid.initialize({startOnLoad:true,theme:'default'});</script>
