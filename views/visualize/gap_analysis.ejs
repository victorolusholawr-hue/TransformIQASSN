<div class="container-wide">
  <div class="page-header">
    <div>
      <h1>Gap Analysis</h1>
      <p class="page-sub"><a href="/projects/<%= project.id %>"><%= project.name %></a></p>
    </div>
    <div class="header-actions">
      <% if (member.role !== 'viewer') { %>
        <form method="POST" action="/projects/<%= project.id %>/visualize/gap-analysis">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-primary"><%= insight ? 'Regenerate' : 'Generate' %> Gap Analysis</button>
        </form>
      <% } %>
      <a href="/projects/<%= project.id %>" class="btn-outline">← Project</a>
    </div>
  </div>

  <div class="stats-grid" style="margin-bottom:20px;">
    <% for (const [key, count] of Object.entries(stats || {})) { %>
      <div class="stat-card">
        <div class="stat-number"><%= count %></div>
        <div class="stat-label"><%= key.replace('_', ' ').replace(/\b\w/g, c => c.toUpperCase()) %></div>
      </div>
    <% } %>
  </div>

  <% if (generated_at) { %>
    <p class="muted" style="margin-bottom:16px;">Last generated: <%= new Date(generated_at).toLocaleString() %></p>
  <% } %>

  <% if (!insight) { %>
    <% if (!stats || !stats.requirements) { %>
      <div class="empty-state"><p>No entities extracted yet. Upload and analyse sources first.</p></div>
    <% } else { %>
      <div class="empty-state"><p>No gap analysis yet. Click Generate to create one with AI.</p></div>
    <% } %>
  <% } else { %>
    <div class="g2" style="margin-bottom:18px;">
      <div class="card"><h3>Current State</h3><p><%= insight.current_state || '—' %></p></div>
      <div class="card"><h3>Future State</h3><p><%= insight.future_state || '—' %></p></div>
    </div>

    <% const gaps = insight.gaps || []; %>
    <% if (gaps.length) { %>
      <div class="section">
        <div class="section-header"><h3>Identified Gaps & Recommendations</h3></div>
        <div class="gap-list">
          <% gaps.forEach(function(g, idx){ %>
            <div class="gap-item">
              <div class="gap-header">
                <strong><%= idx + 1 %>. <%= g.area || 'Gap' %></strong>
                <% if (g.priority) { %><span class="badge-<%= g.priority === 'high' ? 'danger' : g.priority === 'medium' ? 'warning' : 'muted' %>"><%= g.priority %></span><% } %>
              </div>
              <% if (g.issue) { %><p class="gap-issue"><%= g.issue %></p><% } %>
              <% if (g.current) { %><div class="gap-row"><span class="gap-label">Current:</span> <%= g.current %></div><% } %>
              <% if (g.desired) { %><div class="gap-row"><span class="gap-label">Desired:</span> <%= g.desired %></div><% } %>
              <% if (g.gap) { %><div class="gap-row"><span class="gap-label">Gap:</span> <%= g.gap %></div><% } %>
              <% if (g.recommendation) { %><div class="gap-recommendation"><strong>Recommendation:</strong> <%= g.recommendation %></div><% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (insight.recommendations && insight.recommendations.length) { %>
      <div class="section">
        <div class="section-header"><h3>Recommendations</h3></div>
        <ul class="reco-list">
          <% for (const r of insight.recommendations) { %><li><%= r %></li><% } %>
        </ul>
      </div>
    <% } %>
  <% } %>
</div>
